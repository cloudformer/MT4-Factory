# MT4 Factory 环境变量配置示例
# 使用方法：
#   1. 复制此文件为 .env
#   2. 填写实际值
#   3. .env文件不会被git追踪（已在.gitignore中）

# ==================== 环境标识 ====================
ENV=windows                           # windows/production

# ==================== 数据库配置 ====================
# PostgreSQL
POSTGRES_PASSWORD=evo_trade_pass_dev_2024

# 生产环境（云端）
# POSTGRES_HOST=mt4-factory.xxxxx.rds.amazonaws.com
# POSTGRES_PORT=5432
# POSTGRES_DB=evo_trade
# POSTGRES_USER=evo_trade_user

# ==================== MT5配置（Demo）====================
# Windows本地
MT5_DEMO_HOST=host.docker.internal
MT5_DEMO_PORT=9090
MT5_DEMO_LOGIN=5049130509
MT5_DEMO_PASSWORD=your_demo_password_here
MT5_DEMO_SERVER=MetaQuotes-Demo
MT5_DEMO_API_KEY=demo_key_12345

# 云端（替换为实际IP）
# MT5_DEMO_HOST=52.10.20.30
# MT5_DEMO_PORT=9090
# MT5_DEMO_API_KEY=prod_demo_key_STRONG_PASSWORD

# ==================== MT5配置（真实交易）⚠️ ====================
# 注意：真实交易配置请谨慎设置，确保密钥安全
MT5_REAL_HOST=52.10.20.40
MT5_REAL_PORT=9091
MT5_REAL_LOGIN=8012345678
MT5_REAL_PASSWORD=your_real_password_here
MT5_REAL_SERVER=ICMarkets-Live
MT5_REAL_API_KEY=prod_real_key_SUPER_STRONG_PASSWORD

# ==================== MT5 API Bridge配置 ====================
# 如果配置了API密钥，MT5 API Bridge将启用认证
# 多个密钥用逗号分隔
MT5_API_KEYS=demo_key_12345,validator_key_xxx,execution_key_yyy

# API Bridge监听配置
MT5_API_HOST=0.0.0.0
MT5_API_PORT=9090

# ==================== LLM API配置 ====================
# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# ==================== 监控与告警 ====================
# Slack Webhook（用于告警）
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Email告警
ALERT_EMAIL=alerts@your-domain.com

# ==================== 安全配置 ====================
# API密钥（用于服务间认证）
API_SECRET_KEY=your-api-secret-key-generate-random-string-here

# ==================== 备份配置 ====================
# AWS S3（用于数据库备份）
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
BACKUP_S3_BUCKET=mt4-factory-backups

# ==================== Validator配置 ====================
VALIDATOR_CONCURRENCY=20              # 并发验证数
VALIDATOR_SCHEDULE_INTERVAL=3600      # 执行间隔（秒）

# ==================== 其他配置 ====================
# 时区
TZ=UTC

# 日志级别
LOG_LEVEL=INFO

# 调试模式（开发环境）
DEBUG=false
